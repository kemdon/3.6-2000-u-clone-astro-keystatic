---
import BaseLayout from '@/layouts/BaseLayout.astro';
import StructuredPageBlocks from '@/components/sections/StructuredPageBlocks.astro';
import { getCategoriesBySlugs, getPageBySlug, getSite, textToParagraphs } from '@/lib/content';

const [page, site] = await Promise.all([getPageBySlug('contact'), getSite()]);
if (!page) throw new Error('Missing page content: contact');
const linkedCategories = await getCategoriesBySlugs(page.linkedCategorySlugs ?? []);
---

<BaseLayout title={page.seo.title || page.title} description={page.seo.description || page.summary} image={page.seo.image?.src}>
  <section class="section">
    <div class="container">
      <div class="eyebrow">Contact</div>
      <h1 class="section-title">{page.title}</h1>
      {page.heroText ? <p class="section-copy" style="max-width:72ch;">{page.heroText}</p> : null}
      <div class="grid" style="grid-template-columns:1.1fr .9fr;">
        <div class="panel content-prose">
          {textToParagraphs(page.body || page.summary).map((paragraph) => <p>{paragraph}</p>)}
        </div>
        <div class="panel">
          <h2 style="margin-top:0;">Reach Us</h2>
          <p class="section-copy">{site.companyName}</p>
          <p class="section-copy">{site.address}</p>
          <p class="section-copy">{site.email}</p>
          <p class="section-copy">{site.phone}</p>
          {site.whatsapp ? <p class="section-copy">{site.whatsapp}</p> : null}
        </div>
      </div>
    </div>
  </section>
  <StructuredPageBlocks page={page} linkedCategories={linkedCategories} showBody={false} />
</BaseLayout>
